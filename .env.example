# =============================================================================
# NPUHacker v3 - Environment Configuration
# =============================================================================

# LLM server URL (leave empty for auto-detect)
# Examples:
#   Ollama:    http://127.0.0.1:11434/v1
#   vLLM:      http://127.0.0.1:8000/v1
#   LM Studio: http://127.0.0.1:1234/v1
#   Remote:    http://<vast.ai-ip>:11434/v1
LLM_URL=

# Planning model - used for hypothesis generation, chain analysis, reasoning
# This should be your BEST model. Examples:
#   96GB VRAM: qwen3.5:32b (recommended)
#   48GB VRAM: qwen3.5:14b
#   16GB VRAM: qwen3.5:4b
#   8GB VRAM:  qwen3:8b
LLM_MODEL=

# Fast model - used for compression, output parsing, execution tasks
# This should be your FASTEST model. Leave empty to use LLM_MODEL for everything.
# Examples: qwen3.5:4b, qwen3:0.6b, gemma3:1b
LLM_FAST_MODEL=

# Embedding model - used for ToolRAG retrieval
# Leave empty to use LLM_MODEL (or bag-of-words fallback if embeddings unsupported)
# Recommended: nomic-embed-text
LLM_EMBED_MODEL=

# Max context tokens per LLM call
# 96GB VRAM: 32768 or higher
# 16GB VRAM: 8192
# 8GB VRAM:  4096
MAX_CONTEXT_TOKENS=8192
